# Copy to ".env.local" and fill in real values. Do not commit .env.local.
# MONGODB_URI and passwords must stay server-only (no NEXT_PUBLIC_ prefix).

MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.example.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=certverify

NEXT_PUBLIC_APP_BASE_URL=http://localhost:3000

# Optional session cookie name (see src/lib/server/session-cookie-name.ts)
SESSION_COOKIE_NAME=aw-certverify
# APPWRITE_COOKIE_NAME=

# SendGrid — certificate emails + auth verify/reset (preferred on cloud hosts; Gmail SMTP often timeouts)
SENDGRID_API_KEY=
EMAIL_SENDER=

# Auth email: verify + password reset (Nodemailer SMTP)
# Gmail: port 587 + SMTP_ENCRYPTION=tls (STARTTLS), or port 465 + SMTP_ENCRYPTION=ssl
# Do not put the port number in SMTP_ENCRYPTION (use tls | ssl | starttls).
SMTP_HOST=
SMTP_PORT=
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_ENCRYPTION=tls
SMTP_SENDER_EMAIL=
